# ──────────────────────────────────────────────────────────────
# Zkopíruj tento soubor jako .env a doplň reálné hodnoty.
# .env je v .gitignore a NIKDY se necommituje.
# ──────────────────────────────────────────────────────────────

# --- Firebase (klient) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Stripe (server) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Rozvoz: Wolt Drive (server) — až po merchant onboardingu ---
WOLT_DRIVE_API_KEY=
WOLT_DRIVE_VENUE_ID=
WOLT_WEBHOOK_SECRET=

# --- Rozvoz: Foodora / Delivery Hero (server) — až po onboardingu ---
FOODORA_API_KEY=
FOODORA_WEBHOOK_SECRET=

# --- AI vrstva (server, fáze 3) ---
ANTHROPIC_API_KEY=

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
